pipeline {
     agent any
     stages {
          stage ('checkout') {
             steps {
                 echo 'Chckout completed'
                   }
          }
          stage('Build') {
             steps {
               sh '''
               echo "PATH=$PATH"
               which mvn
              mvn -version
              '''
             }
         }
          stage ('Test') {
            steps {
                 sh 'mvn test'
                  }
          }
          stage ('PAckage') {
            steps {
                 sh 'mvn package'
                  }
          }
          stage('Deploy') {
            steps {
                echo 'Deployment completed successfully.'
            }
          } 
     }
     post {
        success {
          echo 'Deployed successfuly'
        }
        failure {
          echo 'Build Failed '
        }
     }
}
